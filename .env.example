# Netlify Identity Configuration
# Set this to your Netlify site URL (e.g. https://your-site.netlify.app).
# This is required so the Netlify Identity widget can reach the correct
# /.netlify/identity endpoint even when running on a custom domain or locally.
# Without this the widget defaults to window.location.origin which may fail
# (showing "Failed to load settings from /.netlify/identity").
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# Bootstrap admin user (first login with this email gets admin role automatically)
BOOTSTRAP_ADMIN_EMAIL=your-email@example.com
